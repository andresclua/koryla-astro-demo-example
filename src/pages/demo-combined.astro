---
import Layout from '../layouts/Layout.astro'
import Experiment from '../components/Experiment.astro'
import Variant from '../components/Variant.astro'
import DemoHeader from '../components/demo/DemoHeader.astro'
import HowToTest from '../components/demo/HowToTest.astro'
import CodeDiagram from '../components/demo/CodeDiagram.astro'
---

<!--
  CONTROL variant of the combined experiment.
  Layer 1 — Edge: assigned "control" → served this file via context.next().
  Layer 2 — SDK: <Experiment> below handles a second, independent CTA split.
  Add ?variant=b to force the edge to rewrite to /demo-combined-b.
-->
<Layout title="Demo Combined" variant="control — /demo-combined">
  <main class="page">

    <DemoHeader
      type="COMBINED"
      badge="COMBINED: EDGE + SDK · CONTROL"
      title="Two layers of control"
      description='Edge handles the <strong>big split</strong> (which page). SDK handles the <strong>fine detail</strong> (which component). Add <code>?variant=b</code> to force variant B.'
    />

    <!--
      SDK layer: runs server-side AFTER the edge already decided which page to serve.
      This experiment is independent — it can have its own traffic split and UTM rules.
    -->
    <Experiment id="bb1e7469-062c-4426-98ad-9b5ca8869f1b">

      <!-- SDK control: default CTA -->
      <Variant slot="control">
        <a href="/thank-you" class="btn btn--terracotta">Start testing free →</a>
      </Variant>

      <!-- SDK variant b: triggered by ?utm_text=variation-1 -->
      <Variant slot="b">
        <a href="/thank-you" class="btn btn--navy">A/B test in 5 min →</a>
      </Variant>

    </Experiment>

    <HowToTest
      steps={[
        'Visit this URL → edge assigns control (50%) → SDK assigns CTA variant',
        'Add <code>?variant=b</code> → edge rewrites to /demo-combined-b (variant B layout)',
        'Both layers can be tuned independently in the Koryla dashboard',
      ]}
      githubPath="/src/pages/demo-combined.astro"
      btnColor="#059669"
    />

    <CodeDiagram lines={[
      { color: 'comment', text: '// Two independent layers for this request' },
      { color: 'edge',    text: 'Layer 1 — Edge: /demo-combined → assigned control → context.next()' },
      { color: 'sdk',     text: 'Layer 2 — SDK: &lt;Experiment&gt; → UTM check → renders active CTA slot' },
      { color: 'comment', text: '// Try: /demo-combined?variant=b → edge rewrites to /demo-combined-b' },
    ]} />

  </main>
</Layout>

<style>
  .page { max-width: 900px; margin: 0 auto; padding: 80px 40px; text-align: center; display: flex; flex-direction: column; gap: 32px; align-items: center; }
  .btn { display: inline-block; padding: 16px 40px; border-radius: 14px; font-weight: 700; font-size: 17px; text-decoration: none; color: #fff; }
  .btn--terracotta { background: #C96A3F; }
  .btn--navy       { background: #0F2235; }
</style>
