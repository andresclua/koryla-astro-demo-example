---
import Layout from '../layouts/Layout.astro'
import Experiment from '../components/Experiment.astro'
import Variant from '../components/Variant.astro'
import DemoHeader from '../components/demo/DemoHeader.astro'

const steps = [
  { label: 'Edge Layer', desc: '?variant=b matched UTM rule → rewrote request to /demo-combined-b' },
  { label: 'Edge Layer', desc: 'Set cookie for the page-level assignment' },
  { label: 'SDK Layer',  desc: '<Experiment> evaluated the CTA variant independently' },
  { label: 'SDK Layer',  desc: 'Rendered only the active &lt;slot&gt; — other variant never sent to browser' },
  { label: 'Result',     desc: 'Browser sees /demo-combined, gets full variant B experience' },
]
---

<!--
  VARIANT B of the combined experiment.
  This page is reached via edge rewrite when ?variant=b is in the URL.
  The <Experiment> below is a second, independent A/B test running inside this page.
-->
<Layout title="Demo Combined" variant="variant-b — /demo-combined-b">
  <main class="page">
    <div class="grid">

      <!-- Left: variant B content with nested SDK experiment -->
      <div>
        <DemoHeader
          type="COMBINED"
          badge="COMBINED: EDGE + SDK · VARIANT B"
          title="Edge brought you here. SDK handles the rest."
          description='The edge function rewrote <code>/demo-combined?variant=b</code> to this page. Now the SDK experiment assigns the CTA independently.'
        />

        <!--
          Second layer: SDK experiment nested inside edge variant B.
          Completely independent traffic split from the edge-level experiment above.
        -->
        <Experiment id="bb1e7469-062c-4426-98ad-9b5ca8869f1b">

          <Variant slot="control">
            <a href="/thank-you" class="btn btn--terracotta">Start testing free →</a>
          </Variant>

          <Variant slot="b">
            <a href="/thank-you" class="btn btn--navy">A/B test in 5 min →</a>
          </Variant>

        </Experiment>
      </div>

      <!-- Right: trace of both layers -->
      <div class="trace-box">
        <p class="trace-title">What happened (2 layers):</p>
        {steps.map(({ label, desc }) => (
          <div class="step">
            <span class="step-label">{label}</span>
            <p class="step-desc" set:html={desc} />
          </div>
        ))}
        <a href="https://github.com/andresclua/koryla-astro-demo-example/blob/main/netlify/edge-functions/koryla.ts" target="_blank" class="link-btn">
          View koryla.ts on GitHub →
        </a>
      </div>

    </div>
  </main>
</Layout>

<style>
  .page { max-width: 1100px; margin: 0 auto; padding: 80px 40px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }

  .btn { display: inline-block; padding: 14px 28px; border-radius: 12px; font-weight: 700; font-size: 15px; text-decoration: none; color: #fff; }
  .btn--terracotta { background: #C96A3F; }
  .btn--navy       { background: #0F2235; }

  .trace-box { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 20px; padding: 28px; }
  .trace-title { font-size: 13px; font-weight: 700; color: #059669; margin-bottom: 16px; }
  .step { margin-bottom: 12px; }
  .step-label { font-size: 11px; font-weight: 700; color: #059669; text-transform: uppercase; }
  .step-desc { font-size: 13px; color: #4b5563; margin-top: 2px; }

  .link-btn { display: inline-flex; align-items: center; gap: 6px; background: #059669; color: #fff; padding: 10px 18px; border-radius: 8px; font-size: 12px; font-weight: 600; text-decoration: none; margin-top: 20px; }
</style>
