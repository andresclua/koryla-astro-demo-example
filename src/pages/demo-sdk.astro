---
import Layout from '../layouts/Layout.astro'
import Experiment from '../components/Experiment.astro'
import Variant from '../components/Variant.astro'
import DemoHeader from '../components/demo/DemoHeader.astro'
import HowToTest from '../components/demo/HowToTest.astro'
import CodeDiagram from '../components/demo/CodeDiagram.astro'
---

<Layout title="Demo SDK" variant="SDK — /demo-sdk">
  <main class="page">

    <DemoHeader
      type="SDK"
      badge="SDK EXPERIMENT"
      title="Component-level A/B test"
      description="Same URL, different CTA text. No URL rewrite needed — variant assigned server-side by <code>&lt;Experiment&gt;</code>."
    />

    <!--
      <Experiment> calls getVariant() in the Astro server.
      It checks ?utm_text first, then the cookie, then assigns randomly.
      Only the matching <Variant slot="..."> is rendered — the other never reaches the browser.
    -->
    <Experiment id="bb1e7469-062c-4426-98ad-9b5ca8869f1b">

      <!-- Shown when no UTM param is present -->
      <Variant slot="control">
        <a href="/thank-you" class="btn btn--terracotta">Start testing free →</a>
        <p class="hint">control · default variant</p>
      </Variant>

      <!-- Shown only when ?utm_text=variation-1 is in the URL -->
      <Variant slot="b">
        <a href="/thank-you" class="btn btn--navy">A/B test in 5 min →</a>
        <p class="hint">variant b · triggered by <code>?utm_text=variation-1</code></p>
      </Variant>

    </Experiment>

    <HowToTest
      steps={[
        'Open this page without UTM → see control CTA (terracotta)',
        'Add <code>?utm_text=variation-1</code> to the URL → see variant B CTA (navy)',
      ]}
      githubPath="/src/pages/demo-sdk.astro"
    />

    <CodeDiagram lines={[
      { color: 'comment',  text: '// What runs where' },
      { color: 'edge',     text: 'Edge function → NOT involved (no URL rewrite for SDK experiments)' },
      { color: 'sdk',      text: 'Astro server → getVariant() checks UTM param → assigns variant' },
      { color: 'sdk',      text: 'Astro server → UTM match does NOT set a sticky cookie' },
      { color: 'sdk',      text: '&lt;Experiment&gt; → renders only the active &lt;slot&gt;' },
    ]} />

  </main>
</Layout>

<style>
  .page { max-width: 900px; margin: 0 auto; padding: 80px 40px; text-align: center; display: flex; flex-direction: column; gap: 32px; }
  .btn { display: inline-block; padding: 16px 40px; border-radius: 14px; font-weight: 700; font-size: 17px; text-decoration: none; color: #fff; }
  .btn--terracotta { background: #C96A3F; }
  .btn--navy       { background: #0F2235; }
  .hint { font-size: 12px; color: #9ca3af; margin-top: 12px; }
</style>
