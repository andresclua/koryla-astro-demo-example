---
import Layout from '../layouts/Layout.astro'
import DemoHeader from '../components/demo/DemoHeader.astro'

// Steps shown in the trace box — what the edge function did step by step
const steps = [
  'Intercepted GET /demo-edge',
  'No cookie found → 50/50 random → you got variant B',
  'Rewrote request to /demo-edge-b (transparent to browser)',
  'Set-Cookie ky_&lt;id&gt;=&lt;variant-b-uuid&gt;',
  'Your browser still shows /demo-edge ✓',
]
---

<!--
  VARIANT B of the edge experiment.
  This URL (/demo-edge-b) is NEVER accessed directly.
  The edge function rewrites /demo-edge → /demo-edge-b when variant B is assigned.
-->
<Layout title="Demo Edge" variant="variant-b — /demo-edge-b">
  <main class="page">
    <div class="grid">

      <!-- Left: variant B content -->
      <div>
        <DemoHeader
          type="EDGE"
          badge="EDGE EXPERIMENT · VARIANT B"
          title="You're seeing Variant B"
          description='The edge function rewrote your request from <code>/demo-edge</code> to <code>/demo-edge-b</code> — completely transparent to the browser.'
        />

        <!-- Variant B CTA — different from control -->
        <a href="/thank-you" class="btn">Start your first test →</a>
      </div>

      <!-- Right: step-by-step trace of the edge function -->
      <div class="trace-box">
        <p class="trace-title">Edge function did this:</p>
        {steps.map((text, i) => (
          <div class="step">
            <span class="step-num">{i + 1}.</span>
            <span set:html={text} />
          </div>
        ))}
        <a href="https://github.com/andresclua/koryla-astro-demo-example/blob/main/netlify/edge-functions/koryla.ts" target="_blank" class="link-btn">
          View koryla.ts on GitHub →
        </a>
      </div>

    </div>
  </main>
</Layout>

<style>
  .page { max-width: 1100px; margin: 0 auto; padding: 80px 40px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .btn { display: inline-block; background: #0F2235; color: #fff; padding: 14px 28px; border-radius: 12px; font-weight: 700; font-size: 15px; text-decoration: none; }

  .trace-box { background: #F5EDE0; border-radius: 20px; padding: 28px; }
  .trace-title { font-size: 13px; font-weight: 700; color: #C96A3F; margin-bottom: 16px; }
  .step { display: flex; gap: 12px; margin-bottom: 12px; font-size: 14px; color: #4b5563; }
  .step-num { color: #C96A3F; font-weight: 700; min-width: 20px; }

  .link-btn { display: inline-flex; align-items: center; gap: 6px; background: #C96A3F; color: #fff; padding: 10px 18px; border-radius: 8px; font-size: 12px; font-weight: 600; text-decoration: none; margin-top: 20px; }
</style>
