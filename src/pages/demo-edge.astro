---
import Layout from '../layouts/Layout.astro'
import DemoHeader from '../components/demo/DemoHeader.astro'
import CodeDiagram from '../components/demo/CodeDiagram.astro'
---

<!--
  CONTROL variant of the edge experiment.
  The Netlify edge function ran BEFORE this page rendered:
  it assigned this visitor to "control" and called context.next() — no rewrite.
  The browser always sees /demo-edge regardless of which variant was assigned.
-->
<Layout title="Demo Edge" variant="control — /demo-edge">
  <main class="page">

    <DemoHeader
      type="EDGE"
      badge="EDGE EXPERIMENT · CONTROL"
      title="You're seeing the control variant"
      description='The Netlify edge function assigned you to <strong>control</strong>. The browser always sees <code>/demo-edge</code> — no redirect happened.'
    />

    <!-- Control CTA — 50% of visitors land here -->
    <a href="/thank-you" class="btn">Get started free →</a>

    <CodeDiagram lines={[
      { color: 'comment', text: '// What the edge function did for YOU' },
      { color: 'edge',    text: 'Request: GET /demo-edge' },
      { color: 'edge',    text: 'Edge: no cookie → random assignment → <span style="color:#86efac">control (50%)</span>' },
      { color: 'edge',    text: 'Edge: target path === request path → context.next() (no rewrite)' },
      { color: 'edge',    text: 'Edge: Set-Cookie ky_&lt;id&gt;=&lt;control-uuid&gt;' },
      { color: 'comment', text: '// 50% of visitors get /demo-edge-b instead (same browser URL)' },
    ]} />

    <a href="https://github.com/andresclua/koryla-astro-demo-example/blob/main/src/pages/demo-edge.astro" target="_blank" class="link-btn">
      View demo-edge.astro on GitHub →
    </a>

  </main>
</Layout>

<style>
  .page { max-width: 900px; margin: 0 auto; padding: 80px 40px; text-align: center; display: flex; flex-direction: column; gap: 32px; align-items: center; }
  .btn { display: inline-block; background: #C96A3F; color: #fff; padding: 16px 40px; border-radius: 14px; font-weight: 700; font-size: 17px; text-decoration: none; }
  .link-btn { display: inline-flex; align-items: center; gap: 6px; background: #C96A3F; color: #fff; padding: 10px 18px; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; }
</style>
