---
import Layout from '../layouts/Layout.astro'

// CONTROL variant: 3-tier pricing (Hobby / Pro / Enterprise)
const plans = [
  {
    name: 'HOBBY', price: '$0', period: '/month forever',
    cta: 'Get started', ctaClass: 'btn btn--ghost',
    features: ['10,000 events/mo', '1 site', '30-day retention'],
  },
  {
    name: 'PRO', price: '$29', period: '/month',
    cta: 'Start free trial', ctaClass: 'btn btn--primary', popular: true,
    features: ['1M events/mo', '10 sites', '1-year retention', 'Custom dashboards'],
  },
  {
    name: 'ENTERPRISE', price: '$99', period: '/month',
    cta: 'Contact sales', ctaClass: 'btn btn--ghost',
    features: ['Unlimited events', 'Unlimited sites', 'SSO / SAML', 'SLA + priority support'],
  },
]
---

<Layout title="Pricing" variant="control — /pricing">
  <main class="page">

    <h1>Simple pricing</h1>
    <p class="subtitle">Start free. Upgrade when you need more.</p>

    <div class="grid">
      {plans.map((plan) => (
        <div class:list={['plan', plan.popular && 'plan--popular']}>
          {plan.popular && <span class="popular-badge">MOST POPULAR</span>}
          <p class="plan__name">{plan.name}</p>
          <p class="plan__price">{plan.price}</p>
          <p class="plan__period">{plan.period}</p>
          <a href="/thank-you" class={plan.ctaClass}>{plan.cta}</a>
          <ul class="features">
            {plan.features.map(f => <li>✓ {f}</li>)}
          </ul>
        </div>
      ))}
    </div>

  </main>
</Layout>

<style>
  .page { max-width: 900px; margin: 0 auto; padding: 80px 40px; text-align: center; }

  h1 { font-size: 48px; font-weight: 800; letter-spacing: -1.5px; margin-bottom: 12px; color: #0F2235; }
  .subtitle { color: #6b7280; font-size: 17px; margin-bottom: 56px; }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

  .plan { border: 1px solid #e5e7eb; border-radius: 20px; padding: 28px; text-align: left; position: relative; }
  .plan--popular { border: 2px solid #C96A3F; }

  .popular-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: #C96A3F; color: #fff; font-size: 11px; font-weight: 700; padding: 4px 12px; border-radius: 999px; white-space: nowrap; }

  .plan__name   { font-size: 13px; font-weight: 600; color: #6b7280; margin-bottom: 12px; }
  .plan__price  { font-size: 40px; font-weight: 800; letter-spacing: -1px; color: #0F2235; }
  .plan__period { color: #9ca3af; font-size: 13px; margin-bottom: 24px; }

  .btn { display: block; text-align: center; border-radius: 10px; padding: 10px; font-size: 14px; font-weight: 600; text-decoration: none; margin-bottom: 24px; }
  .btn--primary { background: #C96A3F; color: #fff; }
  .btn--ghost   { border: 1px solid #e5e7eb; color: #374151; }

  .features { list-style: none; font-size: 14px; color: #4b5563; display: flex; flex-direction: column; gap: 10px; }
</style>
