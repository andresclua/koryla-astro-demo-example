---
import Layout from '../layouts/Layout.astro'

// VARIANT B: 2-tier pricing with annual billing toggle
const plans = [
  {
    name: 'Starter', emoji: '📊',
    tagline: 'For indie devs and small teams',
    price: '$19', period: '/month · billed monthly',
    cta: 'Start 14-day trial', ctaClass: 'btn btn--ghost',
    features: ['500K events/mo', '5 sites', '6-month retention'],
  },
  {
    name: 'Growth', emoji: '🚀',
    tagline: 'For growing products',
    price: '$49', period: '/month · billed monthly',
    cta: 'Start 14-day trial →', ctaClass: 'btn btn--primary', popular: true,
    features: ['Unlimited events', 'Unlimited sites', '2-year retention', 'A/B testing built in'],
  },
]
---

<Layout title="Pricing" variant="variant-b — /pricing-b">
  <main class="page">

    <h1>Try free for <span class="accent">14 days</span></h1>
    <p class="subtitle">No credit card needed. Cancel anytime.</p>

    <!-- Billing toggle (decorative) -->
    <div class="toggle">
      <span class="toggle__active">Monthly</span>
      <span class="toggle__muted">Annual</span>
      <span class="toggle__badge">Save 20%</span>
    </div>

    <div class="grid">
      {plans.map((plan) => (
        <div class:list={['plan', plan.popular && 'plan--popular']}>
          {plan.popular && <span class="popular-badge">BEST VALUE</span>}
          <div class="plan__icon">{plan.emoji}</div>
          <p class="plan__name">{plan.name}</p>
          <p class="plan__tagline">{plan.tagline}</p>
          <p class="plan__price">{plan.price}</p>
          <p class="plan__period">{plan.period}</p>
          <a href="/thank-you" class={plan.ctaClass}>{plan.cta}</a>
          <ul class="features">
            {plan.features.map(f => <li><span class="check">✓</span>{f}</li>)}
          </ul>
        </div>
      ))}
    </div>

  </main>
</Layout>

<style>
  .page { max-width: 900px; margin: 0 auto; padding: 80px 40px; text-align: center; }

  h1 { font-size: 48px; font-weight: 800; letter-spacing: -1.5px; margin-bottom: 12px; color: #0F2235; }
  .accent { color: #C96A3F; }
  .subtitle { color: #6b7280; font-size: 17px; margin-bottom: 16px; }

  .toggle { display: inline-flex; align-items: center; gap: 10px; background: #f3f4f6; border-radius: 999px; padding: 6px 16px; margin-bottom: 48px; font-size: 14px; font-weight: 600; }
  .toggle__active { color: #0F2235; }
  .toggle__muted  { color: #9ca3af; }
  .toggle__badge  { background: #C96A3F; color: #fff; font-size: 11px; padding: 2px 8px; border-radius: 999px; }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 680px; margin: 0 auto; }

  .plan { border: 1px solid #e5e7eb; border-radius: 24px; padding: 32px; text-align: left; background: #fff; position: relative; }
  .plan--popular { border: 2px solid #C96A3F; background: #FEF0E8; }

  .popular-badge { position: absolute; top: -13px; right: 20px; background: #C96A3F; color: #fff; font-size: 11px; font-weight: 700; padding: 4px 14px; border-radius: 999px; }

  .plan__icon    { width: 36px; height: 36px; background: #F5EDE0; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; font-size: 18px; }
  .plan--popular .plan__icon { background: #C96A3F; }
  .plan__name    { font-size: 15px; font-weight: 700; color: #0F2235; margin-bottom: 4px; }
  .plan__tagline { font-size: 13px; color: #9ca3af; margin-bottom: 16px; }
  .plan__price   { font-size: 36px; font-weight: 800; letter-spacing: -1px; color: #0F2235; margin-bottom: 4px; }
  .plan__period  { font-size: 13px; color: #9ca3af; margin-bottom: 24px; }

  .btn { display: block; text-align: center; border-radius: 12px; padding: 12px; font-size: 14px; font-weight: 600; text-decoration: none; margin-bottom: 24px; }
  .btn--primary { background: #C96A3F; color: #fff; font-weight: 700; }
  .btn--ghost   { background: #F5EDE0; color: #0F2235; }

  .features { list-style: none; font-size: 14px; color: #4b5563; display: flex; flex-direction: column; gap: 8px; }
  .plan--popular .features { color: #0F2235; }
  .features li { display: flex; gap: 8px; }
  .check { color: #C96A3F; }
</style>
