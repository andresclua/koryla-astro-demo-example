---
import Layout from '../layouts/Layout.astro'

const apiKey = import.meta.env.KORYLA_API_KEY ?? ''
const apiUrl = import.meta.env.KORYLA_API_URL ?? 'https://koryla.com'
const COOKIE_PREFIX = 'ky_'

// --- Fire conversion events for any SDK experiment whose conversion_url matches this page ---
// The edge function already handles this for edge experiments.
// For SDK experiments we do it here explicitly so it's visible in the code.
if (apiKey) {
  try {
    const res = await fetch(`${apiUrl}/api/worker/config`, {
      headers: { Authorization: `Bearer ${apiKey}` },
    })
    if (res.ok) {
      const experiments = await res.json() as Array<{
        id: string; conversion_url?: string
      }>

      const sessionId = Astro.cookies.get('ky_session')?.value ?? crypto.randomUUID()
      const thisPath = new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/'

      for (const exp of experiments) {
        if (!exp.conversion_url) continue
        const convPath = new URL(exp.conversion_url).pathname.replace(/\/$/, '') || '/'
        if (convPath !== thisPath) continue

        const variantId = Astro.cookies.get(`${COOKIE_PREFIX}${exp.id}`)?.value
        if (!variantId) continue

        // Fire conversion — non-blocking
        fetch(`${apiUrl}/api/worker/event`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${apiKey}` },
          body: JSON.stringify({ experiment_id: exp.id, variant_id: variantId, session_id: sessionId, event_type: 'conversion' }),
        }).catch(() => {})
      }
    }
  } catch { /* ignore network errors */ }
}
---

<!-- Conversion page — fires a conversion event for every experiment whose conversion_url matches /thank-you -->
<Layout title="Thank you" variant="conversion page">
  <main class="page">

    <div class="icon">✓</div>

    <h1>You're in!</h1>

    <p class="subtitle">Thanks for signing up. Check your inbox for your magic link.</p>

    <a href="/" class="btn">← Back to homepage</a>

    <p class="footnote">
      This is the <strong>conversion page</strong> — Koryla records a conversion event when a user reaches this URL.
    </p>

  </main>
</Layout>

<style>
  .page { max-width: 600px; margin: 0 auto; padding: 120px 40px; text-align: center; }

  .icon { width: 64px; height: 64px; background: #FEF0E8; border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; font-size: 32px; }

  h1 { font-size: 36px; font-weight: 800; letter-spacing: -1px; margin-bottom: 12px; color: #0F2235; }

  .subtitle { color: #6b7280; font-size: 17px; line-height: 1.6; margin-bottom: 40px; }

  .btn { display: inline-block; background: #C96A3F; color: #fff; padding: 12px 28px; border-radius: 12px; font-weight: 600; font-size: 15px; text-decoration: none; }

  .footnote { color: #d1d5db; font-size: 12px; margin-top: 48px; }
</style>
