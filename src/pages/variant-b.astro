---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Homepage" variant="variant-b — /variant-b">
  <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.css" />
  <style slot="head">
    @keyframes koryla-glow {
      0%, 100% { box-shadow: 0 0 12px 2px rgba(201,106,63,0.5); }
      50%       { box-shadow: 0 0 24px 6px rgba(201,106,63,0.9); }
    }
    #tour-trigger {
      animation: koryla-glow 2s ease-in-out infinite;
    }
    #tour-trigger:hover {
      background: #FEF0E8 !important;
      color: #C96A3F !important;
      border-color: #C96A3F !important;
    }
  </style>

  <main style="max-width:1100px;margin:0 auto;padding:80px 40px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">
      <div>
        <!-- CHANGE 1 · Badge copy → social proof angle -->
        <div id="tour-badge" style="display:inline-flex;align-items:center;gap:8px;background:#FEF0E8;color:#C96A3F;font-size:13px;font-weight:600;padding:6px 14px;border-radius:999px;margin-bottom:24px">
          <span style="width:6px;height:6px;background:#C96A3F;border-radius:50%;display:inline-block"></span>
          TRUSTED BY 1,200 TEAMS · NO CREDIT CARD NEEDED
        </div>

        <!-- CHANGE 2 · Headline → outcome-focused -->
        <h1 id="tour-headline" style="font-size:clamp(36px,4vw,56px);font-weight:800;line-height:1.1;letter-spacing:-1.5px;margin-bottom:20px;color:#0F2235">
          Your next best decision<br/>
          <span style="color:#C96A3F">is one test away.</span>
        </h1>

        <!-- CHANGE 3 · Body copy → faster, action-oriented -->
        <p id="tour-body" style="font-size:17px;color:#4b5563;line-height:1.65;margin-bottom:32px">
          Run your first A/B test in under 5 minutes — no code changes,
          no flicker, no developer bottleneck. Just results.
        </p>

        <!-- CHANGE 4 · Plain CTA anchor, no email input, navy #0F2235 -->
        <div style="display:flex;flex-direction:column;align-items:flex-start;gap:0">
          <a id="tour-cta" href="/thank-you" style="display:inline-block;background:#0F2235;color:#fff;padding:12px 24px;border-radius:10px;font-weight:600;font-size:14px;text-decoration:none;cursor:pointer">
            Start free today
          </a>
        </div>
        <p style="font-size:12px;color:#9ca3af;margin-top:10px">Free forever on the hobby plan · Cancel anytime</p>
      </div>

      <!-- Right side: feature cards -->
      <div id="tour-cards" style="display:flex;flex-direction:column;gap:12px">
        {[
          ['⚡', 'Zero flicker', 'Variants are served before the browser renders anything.'],
          ['🔒', 'No client JS', 'Works entirely server-side — ad blockers can\'t interfere.'],
          ['📊', 'Live results', 'See impressions and conversions in your dashboard in real time.'],
          ['🔌', 'Any stack', 'Next.js, Astro, WordPress, Nuxt — one API key, any platform.'],
        ].map(([icon, title, desc]) => (
          <div style="display:flex;gap:16px;align-items:flex-start;background:#F5EDE0;border:1px solid #EAD9C4;border-radius:14px;padding:16px 20px">
            <span style="font-size:22px">{icon}</span>
            <div>
              <p style="font-size:14px;font-weight:700;color:#0F2235">{title}</p>
              <p style="font-size:13px;color:#6b7280;margin-top:2px">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <!-- Fixed bottom-left tour trigger -->
  <button id="tour-trigger" style="position:fixed;bottom:24px;left:24px;z-index:9999;background:#fff;border:1.5px solid #C96A3F;color:#C96A3F;padding:12px 20px;border-radius:12px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;transition:background .2s,color .2s,border-color .2s">
    See what Koryla can do →
  </button>

  <script is:inline src="https://cdn.jsdelivr.net/npm/driver.js@1.3.1/dist/driver.js.iife.js"></script>
  <script is:inline>
    document.getElementById('tour-trigger').addEventListener('click', function () {
      const driver = window.driver.js.driver({
        animate: true,
        overlayOpacity: 0.6,
        showProgress: true,
        popoverClass: 'koryla-tour',
        steps: [
          {
            element: '#tour-badge',
            popover: {
              title: 'Change 1 — Social proof badge',
              side: 'bottom',
              align: 'start',
              description: `<p style="margin-bottom:10px;color:#6b7280;font-size:13px;line-height:1.5">Control showed a plain "BETA" label. Variant b uses social proof copy to build immediate trust.</p>
<pre style="background:#0F2235;color:#F5EDE0;padding:14px 16px;border-radius:8px;font-size:12px;line-height:1.7;overflow:auto;white-space:pre">
<span style="color:#9ca3af">// variant-b.astro</span>
&lt;<span style="color:#C96A3F">KVariant</span> id=<span style="color:#a3e635">"b"</span>&gt;
  &lt;div class=<span style="color:#a3e635">"badge"</span>&gt;
    TRUSTED BY 1,200 TEAMS
    · NO CREDIT CARD NEEDED
  &lt;/div&gt;
&lt;/<span style="color:#C96A3F">KVariant</span>&gt;

<span style="color:#9ca3af">// Koryla assigns this variant</span>
<span style="color:#9ca3af">// at the edge — zero flicker</span>
</pre>`
            }
          },
          {
            element: '#tour-headline',
            popover: {
              title: 'Change 2 — Outcome-focused headline',
              side: 'bottom',
              align: 'start',
              description: `<p style="margin-bottom:10px;color:#6b7280;font-size:13px;line-height:1.5">Control: "The fastest way to run A/B tests". Variant b: leads with the user's outcome, not the product feature.</p>
<pre style="background:#0F2235;color:#F5EDE0;padding:14px 16px;border-radius:8px;font-size:12px;line-height:1.7;overflow:auto;white-space:pre">
<span style="color:#9ca3af">// pages/index.astro</span>
<span style="color:#60a5fa">const</span> variant = <span style="color:#60a5fa">await</span> getVariant(
  Astro.request,
  <span style="color:#a3e635">'hero-headline'</span>
)

<span style="color:#9ca3af">// variant.id === 'b'</span>
<span style="color:#9ca3af">// assigned in &lt;1ms at the edge</span>
<span style="color:#9ca3af">// cookie: ky_hero-headline</span>
</pre>`
            }
          },
          {
            element: '#tour-body',
            popover: {
              title: 'Change 3 — Action-oriented body copy',
              side: 'bottom',
              align: 'start',
              description: `<p style="margin-bottom:10px;color:#6b7280;font-size:13px;line-height:1.5">Control listed 3 features. Variant b makes a single punchy promise focused on time-to-value.</p>
<pre style="background:#0F2235;color:#F5EDE0;padding:14px 16px;border-radius:8px;font-size:12px;line-height:1.7;overflow:auto;white-space:pre">
<span style="color:#9ca3af">// @koryla/react</span>
&lt;<span style="color:#C96A3F">Experiment</span> variantId={variant?.id}&gt;
  &lt;<span style="color:#C96A3F">Variant</span> id=<span style="color:#a3e635">"control"</span>&gt;
    &lt;p&gt;The fastest way to ship
    A/B tests on any platform.&lt;/p&gt;
  &lt;/<span style="color:#C96A3F">Variant</span>&gt;
  &lt;<span style="color:#C96A3F">Variant</span> id=<span style="color:#a3e635">"b"</span>&gt;
    &lt;p&gt;Run your first A/B test
    in under 5 minutes — no code
    changes, no flicker.&lt;/p&gt;
  &lt;/<span style="color:#C96A3F">Variant</span>&gt;
&lt;/<span style="color:#C96A3F">Experiment</span>&gt;
</pre>`
            }
          },
          {
            element: '#tour-cta',
            popover: {
              title: 'Change 4 — Navy CTA, no email gate',
              side: 'top',
              align: 'start',
              description: `<p style="margin-bottom:10px;color:#6b7280;font-size:13px;line-height:1.5">Control had a terracotta button + email input. Variant b removes the field entirely to reduce friction.</p>
<pre style="background:#0F2235;color:#F5EDE0;padding:14px 16px;border-radius:8px;font-size:12px;line-height:1.7;overflow:auto;white-space:pre">
<span style="color:#9ca3af">// CONTROL</span>
&lt;form action=<span style="color:#a3e635">"/thank-you"</span>&gt;
  &lt;input type=<span style="color:#a3e635">"email"</span>
    placeholder=<span style="color:#a3e635">"Work email"</span> /&gt;
  &lt;button style=<span style="color:#a3e635">"background:#C96A3F"</span>&gt;
    Get started
  &lt;/button&gt;
&lt;/form&gt;

<span style="color:#9ca3af">// VARIANT B — less friction</span>
&lt;a href=<span style="color:#a3e635">"/thank-you"</span>
   style=<span style="color:#a3e635">"background:#0F2235"</span>&gt;
  Start free today
&lt;/a&gt;
</pre>`
            }
          },
          {
            element: '#tour-cards',
            popover: {
              title: 'Change 5 — Feature cards replace screenshot',
              side: 'left',
              align: 'start',
              description: `<p style="margin-bottom:10px;color:#6b7280;font-size:13px;line-height:1.5">Control showed a generic product screenshot. Variant b surfaces four concrete value props in scannable cards.</p>
<pre style="background:#0F2235;color:#F5EDE0;padding:14px 16px;border-radius:8px;font-size:12px;line-height:1.7;overflow:auto;white-space:pre">
<span style="color:#9ca3af">// each card — sand palette</span>
{[
  [<span style="color:#a3e635">'⚡'</span>, <span style="color:#a3e635">'Zero flicker'</span>,
    <span style="color:#a3e635">'Served before render'</span>],
  [<span style="color:#a3e635">'🔒'</span>, <span style="color:#a3e635">'No client JS'</span>,
    <span style="color:#a3e635">'Ad-blocker proof'</span>],
  [<span style="color:#a3e635">'📊'</span>, <span style="color:#a3e635">'Live results'</span>,
    <span style="color:#a3e635">'Real-time dashboard'</span>],
  [<span style="color:#a3e635">'🔌'</span>, <span style="color:#a3e635">'Any stack'</span>,
    <span style="color:#a3e635">'One API key'</span>],
].map(([icon, title, desc]) =&gt; (
  &lt;Card
    background=<span style="color:#a3e635">"#F5EDE0"</span>
    border=<span style="color:#a3e635">"#EAD9C4"</span> /&gt;
))}
</pre>`
            }
          },
          {
            element: '#tour-cards',
            popover: {
              title: 'Bonus — Dual analytics reporting',
              side: 'left',
              align: 'start',
              description: `<p style="margin-bottom:10px;color:#6b7280;font-size:13px;line-height:1.5">Koryla reports to its own dashboard <em>and</em> fires an <code style="background:#1e3a5f;padding:2px 6px;border-radius:4px;color:#a3e635">onAssigned</code> callback so you can push the same event to PostHog, GA4, or Segment — no extra setup.</p>
<pre style="background:#0F2235;color:#F5EDE0;padding:14px 16px;border-radius:8px;font-size:12px;line-height:1.7;overflow:auto;white-space:pre">
<span style="color:#9ca3af">// @koryla/react — dual reporting</span>
&lt;<span style="color:#C96A3F">Experiment</span>
  variantId={variant?.id}
  onAssigned={(variantId) =&gt; {
    <span style="color:#9ca3af">// Koryla dashboard ← automatic</span>

    <span style="color:#9ca3af">// PostHog</span>
    posthog.capture(<span style="color:#a3e635">'experiment_viewed'</span>, {
      experiment: <span style="color:#a3e635">'hero-headline'</span>,
      variant: variantId,
    })

    <span style="color:#9ca3af">// GA4</span>
    gtag(<span style="color:#a3e635">'event'</span>, <span style="color:#a3e635">'experiment_viewed'</span>, {
      experiment_id: <span style="color:#a3e635">'hero-headline'</span>,
      variant_id: variantId,
    })
  }}
&gt;
  ...
&lt;/<span style="color:#C96A3F">Experiment</span>&gt;
</pre>`
            }
          }
        ]
      })
      driver.drive()
    })
  </script>
</Layout>
