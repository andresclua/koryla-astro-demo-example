---
interface Props {
  type: 'SDK' | 'EDGE' | 'COMBINED'
  badge: string
  title: string
  description: string
}
const { type, badge, title, description } = Astro.props

const colors: Record<string, { bg: string; text: string }> = {
  SDK:      { bg: '#e0e7ff', text: '#3730a3' },
  EDGE:     { bg: '#FEF0E8', text: '#C96A3F' },
  COMBINED: { bg: '#d1fae5', text: '#065f46' },
}
const c = colors[type]
---

<header class="demo-header">
  <span class="badge" style={`background:${c.bg};color:${c.text}`}>{badge}</span>
  <h1>{title}</h1>
  <p set:html={description} />
</header>

<style>
  .demo-header { text-align: center; max-width: 600px; margin: 0 auto 48px; }
  .badge { display: inline-block; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 999px; margin-bottom: 16px; letter-spacing: .3px; }
  h1 { font-size: clamp(36px, 5vw, 60px); font-weight: 800; line-height: 1.1; letter-spacing: -2px; margin-bottom: 16px; color: #0F2235; }
  p { font-size: 17px; color: #6b7280; line-height: 1.6; }
</style>
