---
interface Props {
  steps: string[]
  githubPath: string
  btnColor?: string
}
const { steps, githubPath, btnColor = '#3730a3' } = Astro.props
const GH = 'https://github.com/andresclua/koryla-astro-demo-example/blob/main'
---

<div class="how-to">
  <p class="label">🧪 HOW TO TEST</p>
  {steps.map((step, i) => <p>{i + 1}. <span set:html={step} /></p>)}
  <a href={GH + githubPath} target="_blank" class="link" style={`background:${btnColor}`}>
    View source on GitHub →
  </a>
</div>

<style>
  .how-to {
    background: #f8faff;
    border: 1px solid #c7d2fe;
    border-radius: 16px;
    padding: 28px;
    text-align: left;
    font-size: 14px;
    color: #4b5563;
    line-height: 1.8;
  }
  .label { font-size: 13px; font-weight: 700; color: #3730a3; margin-bottom: 12px; }
  .link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #fff;
    padding: 10px 18px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    margin-top: 16px;
  }
</style>
