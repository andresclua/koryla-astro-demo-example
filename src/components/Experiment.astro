---
import { getVariant } from '../lib/getVariant'

interface Props {
  id: string
}

const { id } = Astro.props

const apiKey = import.meta.env.KORYLA_API_KEY ?? ''
const apiUrl = import.meta.env.KORYLA_API_URL ?? 'https://koryla.com'

const result = await getVariant(Astro.request, id, { apiKey, apiUrl })

const active = result?.variant.name ?? 'control'

// --- Session ID (mirrors edge function logic) ---
const sessionCookie = Astro.cookies.get('ky_session')?.value
const sessionId = sessionCookie ?? crypto.randomUUID()
const isNewSession = !sessionCookie

// --- Variant cookie ---
if (result?.isNewAssignment) {
  Astro.cookies.set(result.cookieName, result.variantId, {
    maxAge: 60 * 60 * 24 * 30,
    sameSite: 'lax',
    path: '/',
  })
}

if (isNewSession) {
  Astro.cookies.set('ky_session', sessionId, {
    maxAge: 60 * 60 * 24 * 365,
    sameSite: 'lax',
    path: '/',
  })
}

// --- Fire impression event (non-blocking) ---
if (result && apiKey) {
  const reqUrl = new URL(Astro.request.url)
  const ua = Astro.request.headers.get('user-agent') ?? ''
  const deviceType = /tablet|ipad/i.test(ua) ? 'tablet' : /mobile|android|iphone|ipod/i.test(ua) ? 'mobile' : 'desktop'

  fetch(`${apiUrl}/api/worker/event`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${apiKey}` },
    body: JSON.stringify({
      experiment_id: result.experiment.id,
      variant_id: result.variantId,
      session_id: sessionId,
      event_type: 'impression',
      metadata: {
        utm_source: reqUrl.searchParams.get('utm_source') ?? undefined,
        utm_medium: reqUrl.searchParams.get('utm_medium') ?? undefined,
        utm_campaign: reqUrl.searchParams.get('utm_campaign') ?? undefined,
        referrer: Astro.request.headers.get('referer') ?? undefined,
        page_url: reqUrl.pathname,
        device_type: deviceType,
      },
    }),
  }).catch(() => { /* ignore network errors */ })
}

// Render only the active named slot — avoids the dynamic slot[name] compiler error
const html = Astro.slots.has(active)
  ? await Astro.slots.render(active)
  : await Astro.slots.render('control')
---
<Fragment set:html={html} />
